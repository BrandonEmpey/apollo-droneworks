# Database (Neon PostgreSQL)
DATABASE_URL=your_value_here

# Session (required for login/auth to work)
SESSION_SECRET=your_value_here

# Stripe (needed for payment features — leave blank to disable)
# Use sk_test_/pk_test_ for testing, sk_live_/pk_live_ for production
STRIPE_SECRET_KEY=your_value_here
VITE_STRIPE_PUBLIC_KEY=your_value_here
STRIPE_WEBHOOK_SECRET=your_value_here

# SendGrid (needed for email notifications — leave blank to disable)
SENDGRID_API_KEY=your_value_here
SENDGRID_FROM_EMAIL=your_value_here

# App URL (used in email links)
CLIENT_URL=your_value_here

# xAI Grok (needed for AI blog generation and image validation — leave blank to disable)
XAI_API_KEY=your_value_here
